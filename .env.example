# Network: testnet (recommended for development — see README)
SPHERE_NETWORK=testnet

# Gateway API key. The testnet2 key is NOT a secret (published by Unicity in
# their .env.example). For mainnet, this IS a secret — keep it server-side only.
SPHERE_ORACLE_API_KEY=

# Fixed mnemonic so the agent keeps the same identity/nametag across restarts.
# Leave blank on first run to auto-generate one — the server will print it
# once, save it to wallet-data/, and reuse it from then on.
WALLET_MNEMONIC=

# Human-readable @name to register for this agent (3-20 chars, a-z0-9_-)
AGENT_NAMETAG=

# --- Spending guardrails (hard caps enforced in code, not just config) ---
# Maximum total amount (in the smallest unit of MAX_SPEND_COIN) the agent is
# ever allowed to send across all approved deals in a rolling 24h window.
MAX_SPEND_PER_DAY=1000000
MAX_SPEND_COIN=UCT

# Maximum a single proposed deal may be for, regardless of daily cap.
MAX_SPEND_PER_DEAL=200000

# --- Trading strategy ---
TRADE_COIN=UCT
TRADE_TARGET_PRICE_USD=
TRADE_SIDE=buy

# Dashboard server port
PORT=8787
